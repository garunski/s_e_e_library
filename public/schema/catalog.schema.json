{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://garunski.github.io/s_e_e_library/schema/catalog.schema.json",
  "title": "S.E.E. Library catalog manifest",
  "type": "object",
  "required": ["schema", "name", "packages"],
  "properties": {
    "schema": { "const": "see.library/v1" },
    "name": { "type": "string", "minLength": 1 },
    "updated": { "type": "string", "format": "date-time" },
    "packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/package" }
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "category",
        "version",
        "author",
        "verified",
        "license",
        "requires",
        "dependencies",
        "files"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "category": {
          "enum": ["workflow", "prompt", "skill", "rule", "template", "command", "bundle"]
        },
        "version": { "type": "string", "minLength": 1 },
        "author": { "type": "string" },
        "verified": { "type": "boolean" },
        "license": { "type": "string" },
        "requires": { "type": "array", "items": { "type": "string" } },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/file" }
        }
      }
    },
    "file": {
      "type": "object",
      "required": ["to", "from"],
      "properties": {
        "to": {
          "type": "string",
          "pattern": "^(\\.s_e_e/|\\.agents/|\\.cursor/|templates/)[^\\\\]*$"
        },
        "from": { "type": "string", "minLength": 1 }
      }
    }
  }
}
